"mumkin. Biz ushbu Shartlar buzilganda hisobni bloklashga haqlimiz."

#: templates/legal/terms.html:73
msgid "Изменения"
msgstr "O'zgarishlar"

#: templates/legal/terms.html:74
msgid ""
